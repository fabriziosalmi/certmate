# Exclude sensitive environment files
.env
.env.*
*.env

# Virtual environments — NEVER copy into Docker context
.venv/
venv/
venv*/
env/


# Exclude development files
.git
.gitignore
.github
.vscode
.idea
**/node_modules
package.json
# Agent worktrees are full copies of the repository (tens of MB) plus any
# local tool configuration — never ship them (#426).
.claude/
docs/
package-lock.json
tailwind.config.js

# Exclude documentation and metadata
README.md
*.md
screenshot_*.png
CODE_OF_CONDUCT.md
CONTRIBUTING.md
LICENSE

# Exclude Python cache and temporary files.
# '**/' is load-bearing: the bare forms below only matched the context root,
# so every modules/**/__pycache__ shipped in the image (#426).
**/__pycache__
**/*.py[cod]
.Python
**/*.so
.pytest_cache
.coverage
.tox
.cache

# Exclude local development data
certificates/
data/
letsencrypt/
logs/

# Exclude Docker and deployment files
docker-compose.yml
Dockerfile
.dockerignore

# Exclude test and debug files.
# NOTE: a pattern without '**' matches at the CONTEXT ROOT ONLY (#426) — the
# entries below used to leave every nested match in the image.
**/test_*.py
**/*_test.py
**/debug_*.py
tests/
scratch/

# Exclude setup and validation scripts
setup.sh
start.sh
validate_dependencies.py
api_client_example.py

# Exclude any backup files
*.bak
*.backup
*.old
*.orig

# Exclude OS specific files
.DS_Store
Thumbs.db

backups/